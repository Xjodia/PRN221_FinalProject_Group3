@model VerifyEmailCodeViewModel

@{
    ViewData["Title"] = "Xác thực đặt lại mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Xác thực đặt lại mật khẩu - StoryNest</title>
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />
</head>
<body>
    <main class="register-page">
        <section class="register-shell login-shell" aria-labelledby="verify-title">
            <aside class="brand-panel" aria-label="StoryNest">
                <div class="brand-glow"></div>
                <div class="brand-content">
                    <div class="brand-mark" aria-hidden="true">
                        <svg viewBox="0 0 64 64">
                            <path d="M13 13.5c8.4 0 14.7 2.1 19 6.3v31.7c-4.3-4.2-10.6-6.3-19-6.3V13.5Z" />
                            <path d="M51 13.5c-8.4 0-14.7 2.1-19 6.3v31.7c4.3-4.2 10.6-6.3 19-6.3V13.5Z" />
                        </svg>
                    </div>
                    <p class="brand-name">StoryNest</p>
                    <p class="brand-tagline">Chỉ một bước nữa để đặt lại mật khẩu.</p>
                </div>
            </aside>

            <div class="form-panel">
                <div class="form-container login-container">
                    <header class="form-heading">
                        <span class="eyebrow">XÁC THỰC YÊU CẦU</span>
                        <h1 id="verify-title">Nhập mã 6 chữ số</h1>
                        <p>
                            Mã đã được gửi đến <strong>@Model.Email</strong>.
                            Mã sẽ bị hủy sau 5 phút.
                        </p>
                    </header>

                    <form asp-action="VerifyPasswordReset" method="post" class="register-form">
                        <input asp-for="FlowId" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                        <div class="field-group">
                            <label asp-for="Code"></label>
                            <input asp-for="Code"
                                   class="otp-input"
                                   inputmode="numeric"
                                   autocomplete="one-time-code"
                                   maxlength="6"
                                   pattern="[0-9]{6}"
                                   placeholder="000000"
                                   autofocus />
                            <span asp-validation-for="Code" class="field-error"></span>
                        </div>

                        <button class="submit-button" type="submit">
                            <span>Tiếp tục đặt lại mật khẩu</span>
                        </button>

                        <p class="login-prompt">
                            Không nhận được mã hoặc mã đã hết hạn?
                            <a asp-action="ForgotPassword">Gửi yêu cầu mới</a>
                        </p>
                    </form>
                </div>
            </div>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
