@model LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng nhập - StoryNest</title>
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />
</head>
<body>
    <main class="register-page">
        <section class="register-shell login-shell" aria-labelledby="login-title">
            <aside class="brand-panel" aria-label="StoryNest">
                <div class="brand-glow"></div>
                <div class="brand-content">
                    <div class="brand-mark" aria-hidden="true">
                        <svg viewBox="0 0 64 64">
                            <path d="M13 13.5c8.4 0 14.7 2.1 19 6.3v31.7c-4.3-4.2-10.6-6.3-19-6.3V13.5Z" />
                            <path d="M51 13.5c-8.4 0-14.7 2.1-19 6.3v31.7c4.3-4.2 10.6-6.3 19-6.3V13.5Z" />
                            <path class="brand-mark-line" d="M19 22.5c4.2.4 7.2 1.5 9 3.2M19 30.5c4.2.4 7.2 1.5 9 3.2M45 22.5c-4.2.4-7.2 1.5-9 3.2M45 30.5c-4.2.4-7.2 1.5-9 3.2" />
                        </svg>
                    </div>
                    <p class="brand-name">StoryNest</p>
                    <p class="brand-tagline">Trở lại với câu chuyện còn đang dang dở.</p>
                </div>
            </aside>

            <div class="form-panel">
                <div class="form-container login-container">
                    <header class="form-heading">
                        <span class="eyebrow">CHÀO MỪNG TRỞ LẠI</span>
                        <h1 id="login-title">Đăng nhập</h1>
                        <p>Tiếp tục hành trình đọc của bạn trên StoryNest.</p>
                    </header>

                    @if (TempData["SuccessMessage"] is string successMessage)
                    {
                        <div class="success-message">@successMessage</div>
                    }

                    <form asp-controller="Account" asp-action="Login" method="post" class="register-form">
                        <input asp-for="ReturnUrl" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                        <div class="field-group">
                            <label asp-for="Identifier"></label>
                            <input asp-for="Identifier"
                                   placeholder="Tên đăng nhập hoặc name@example.com"
                                   autocomplete="username" autofocus />
                            <span asp-validation-for="Identifier" class="field-error"></span>
                        </div>

                        <div class="field-group">
                            <label asp-for="Password"></label>
                            <div class="password-field">
                                <input asp-for="Password" placeholder="Nhập mật khẩu" autocomplete="current-password" />
                                <button class="toggle-password" type="button" data-password-toggle="Password"
                                        aria-label="Hiện mật khẩu" aria-pressed="false">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
                                        <circle cx="12" cy="12" r="2.5" />
                                    </svg>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="field-error"></span>
                        </div>

                        <div class="login-options">
                            <label class="remember-me">
                                <input asp-for="RememberMe" />
                                <span>Ghi nhớ đăng nhập</span>
                            </label>
                            <a href="#">Quên mật khẩu?</a>
                        </div>

                        <button class="submit-button" type="submit">
                            <span>Đăng nhập</span>
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="m9 18 6-6-6-6" />
                            </svg>
                        </button>

                        <p class="login-prompt">
                            Chưa có tài khoản?
                            <a asp-controller="Account" asp-action="Register">Đăng ký ngay</a>
                        </p>
                    </form>
                </div>
            </div>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        document.querySelectorAll("[data-password-toggle]").forEach((button) => {
            button.addEventListener("click", () => {
                const input = document.getElementById(button.dataset.passwordToggle);
                const isVisible = input.type === "text";
                input.type = isVisible ? "password" : "text";
                button.setAttribute("aria-pressed", String(!isVisible));
                button.setAttribute("aria-label", isVisible ? "Hiện mật khẩu" : "Ẩn mật khẩu");
            });
        });
    </script>
</body>
</html>
