@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Quên mật khẩu - StoryNest</title>
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />
</head>
<body>
    <main class="register-page">
        <section class="register-shell login-shell" aria-labelledby="forgot-title">
            <aside class="brand-panel" aria-label="StoryNest">
                <div class="brand-glow"></div>
                <div class="brand-content">
                    <div class="brand-mark" aria-hidden="true">
                        <svg viewBox="0 0 64 64">
                            <path d="M13 13.5c8.4 0 14.7 2.1 19 6.3v31.7c-4.3-4.2-10.6-6.3-19-6.3V13.5Z" />
                            <path d="M51 13.5c-8.4 0-14.7 2.1-19 6.3v31.7c4.3-4.2 10.6-6.3 19-6.3V13.5Z" />
                        </svg>
                    </div>
                    <p class="brand-name">StoryNest</p>
                    <p class="brand-tagline">Lấy lại quyền truy cập vào tài khoản của bạn.</p>
                </div>
            </aside>

            <div class="form-panel">
                <div class="form-container login-container">
                    <header class="form-heading">
                        <span class="eyebrow">KHÔI PHỤC TÀI KHOẢN</span>
                        <h1 id="forgot-title">Quên mật khẩu?</h1>
                        <p>Nhập Gmail đã đăng ký. StoryNest sẽ gửi mã xác thực 6 chữ số.</p>
                    </header>

                    @if (TempData["ErrorMessage"] is string errorMessage)
                    {
                        <div class="validation-summary">
                            <ul><li>@errorMessage</li></ul>
                        </div>
                    }

                    <form asp-action="ForgotPassword" method="post" class="register-form">
                        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                        <div class="field-group">
                            <label asp-for="Email"></label>
                            <input asp-for="Email"
                                   placeholder="name@gmail.com"
                                   autocomplete="email"
                                   autofocus />
                            <span asp-validation-for="Email" class="field-error"></span>
                        </div>

                        <button class="submit-button" type="submit">
                            <span>Gửi mã xác thực</span>
                        </button>

                        <p class="login-prompt">
                            Đã nhớ mật khẩu?
                            <a asp-action="Login">Quay lại đăng nhập</a>
                        </p>
                    </form>
                </div>
            </div>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
