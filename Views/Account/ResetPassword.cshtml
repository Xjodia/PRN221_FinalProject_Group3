@model ResetPasswordViewModel

@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đặt lại mật khẩu - StoryNest</title>
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />
</head>
<body>
    <main class="register-page">
        <section class="register-shell login-shell" aria-labelledby="reset-title">
            <aside class="brand-panel" aria-label="StoryNest">
                <div class="brand-glow"></div>
                <div class="brand-content">
                    <div class="brand-mark" aria-hidden="true">
                        <svg viewBox="0 0 64 64">
                            <path d="M13 13.5c8.4 0 14.7 2.1 19 6.3v31.7c-4.3-4.2-10.6-6.3-19-6.3V13.5Z" />
                            <path d="M51 13.5c-8.4 0-14.7 2.1-19 6.3v31.7c4.3-4.2 10.6-6.3 19-6.3V13.5Z" />
                        </svg>
                    </div>
                    <p class="brand-name">StoryNest</p>
                    <p class="brand-tagline">Tạo mật khẩu mới an toàn cho tài khoản.</p>
                </div>
            </aside>

            <div class="form-panel">
                <div class="form-container login-container">
                    <header class="form-heading">
                        <span class="eyebrow">MẬT KHẨU MỚI</span>
                        <h1 id="reset-title">Đặt lại mật khẩu</h1>
                        <p>Nhập mật khẩu mới hai lần để hoàn tất.</p>
                    </header>

                    <form asp-action="ResetPassword" method="post" class="register-form">
                        <input asp-for="FlowId" type="hidden" />
                        <input asp-for="Token" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                        <div class="field-group">
                            <label asp-for="NewPassword"></label>
                            <div class="password-field">
                                <input asp-for="NewPassword"
                                       placeholder="Tối thiểu 8 ký tự"
                                       autocomplete="new-password"
                                       autofocus />
                                <button class="toggle-password"
                                        type="button"
                                        data-password-toggle="NewPassword"
                                        aria-label="Hiện mật khẩu"
                                        aria-pressed="false">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
                                        <circle cx="12" cy="12" r="2.5" />
                                    </svg>
                                </button>
                            </div>
                            <span asp-validation-for="NewPassword" class="field-error"></span>
                        </div>

                        <div class="field-group">
                            <label asp-for="ConfirmPassword"></label>
                            <div class="password-field">
                                <input asp-for="ConfirmPassword"
                                       placeholder="Nhập lại mật khẩu mới"
                                       autocomplete="new-password" />
                                <button class="toggle-password"
                                        type="button"
                                        data-password-toggle="ConfirmPassword"
                                        aria-label="Hiện mật khẩu"
                                        aria-pressed="false">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
                                        <circle cx="12" cy="12" r="2.5" />
                                    </svg>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                        </div>

                        <button class="submit-button" type="submit">
                            <span>Đặt lại mật khẩu</span>
                        </button>
                    </form>
                </div>
            </div>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        document.querySelectorAll("[data-password-toggle]").forEach((button) => {
            button.addEventListener("click", () => {
                const input = document.getElementById(button.dataset.passwordToggle);
                const isVisible = input.type === "text";
                input.type = isVisible ? "password" : "text";
                button.setAttribute("aria-pressed", String(!isVisible));
                button.setAttribute("aria-label", isVisible ? "Hiện mật khẩu" : "Ẩn mật khẩu");
            });
        });
    </script>
</body>
</html>
