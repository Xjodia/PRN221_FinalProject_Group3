@model PRN221_FinalProject_Group3.Models.ViewModels.SearchViewModel

@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Query)
        ? "Tìm kiếm"
        : $"Tìm kiếm \"{Model.Query}\"";

    string BuildUrl(string? tab = null, bool clearAdvanced = false)
    {
        var parameters = new List<KeyValuePair<string, string?>>
        {
            new("q", Model.Query),
            new("tab", tab ?? Model.Tab),
            new("status", clearAdvanced ? "all" : Model.Status),
            new("sort", clearAdvanced ? "az" : Model.Sort)
        };

        if (!clearAdvanced && !string.IsNullOrWhiteSpace(Model.Author))
        {
            parameters.Add(new("author", Model.Author));
        }

        if (!clearAdvanced)
        {
            parameters.AddRange(Model.SelectedCategoryIds.Select(categoryId =>
                new KeyValuePair<string, string?>("categoryIds", categoryId.ToString())));
        }

        return $"{Url.Action("Search", "Novel")}{Microsoft.AspNetCore.Http.QueryString.Create(parameters)}";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/search.css" asp-append-version="true" />
}

<section class="search-page">
    <div class="search-shell">
        <header class="search-header">
            <h1>Tìm kiếm</h1>
            <p>
                @if (string.IsNullOrWhiteSpace(Model.Query) && !Model.HasAdvancedFilters)
                {
                    <text>Khám phá toàn bộ truyện hoặc nhập tối thiểu 2 ký tự để tìm kiếm.</text>
                }
                else
                {
                    <text>Tìm thấy @Model.TotalCount kết quả phù hợp.</text>
                }
            </p>
        </header>

        <form class="search-form" asp-controller="Novel" asp-action="Search" method="get">
            <input type="hidden" name="tab" value="@Model.Tab" />

            <div class="search-bar">
                <input type="search"
                       name="q"
                       value="@Model.Query"
                       placeholder="Nhập tên truyện, tác giả..."
                       aria-label="Từ khóa tìm kiếm" />
                <button type="submit">Tìm kiếm</button>
            </div>

            <div class="advanced-search-heading">
                <button id="advancedSearchToggle"
                        class="advanced-search-toggle"
                        type="button"
                        aria-expanded="@Model.HasAdvancedFilters.ToString().ToLowerInvariant()"
                        aria-controls="advancedSearchPanel">
                    <span aria-hidden="true">⚲</span> Tìm kiếm nâng cao
                </button>
            </div>

            <section id="advancedSearchPanel"
                     class="advanced-search-panel"
                     aria-label="Bộ lọc tìm kiếm nâng cao"
                     hidden="@(!Model.HasAdvancedFilters)">
                <div class="advanced-fields">
                    <label class="advanced-field advanced-author">
                        <span>Tác giả</span>
                        <input type="text" name="author" value="@Model.Author" placeholder="Có thể bỏ trống..." />
                    </label>

                    <label class="advanced-field">
                        <span>Tình trạng</span>
                        <select name="status">
                            <option value="all" selected="@(Model.Status == "all")">Tất cả</option>
                            <option value="ongoing" selected="@(Model.Status == "ongoing")">Đang tiến hành</option>
                            <option value="completed" selected="@(Model.Status == "completed")">Hoàn thành</option>
                            <option value="paused" selected="@(Model.Status == "paused")">Tạm dừng</option>
                        </select>
                    </label>

                    <label class="advanced-field">
                        <span>Sắp xếp</span>
                        <select name="sort">
                            <option value="az" selected="@(Model.Sort == "az")">Tên A-Z</option>
                            <option value="relevance" selected="@(Model.Sort == "relevance")">Liên quan</option>
                            <option value="latest" selected="@(Model.Sort == "latest")">Mới nhất</option>
                            <option value="popular" selected="@(Model.Sort == "popular")">Xem nhiều</option>
                        </select>
                    </label>
                </div>

                <fieldset class="category-filter">
                    <legend>Thể loại <small>(có thể chọn nhiều)</small></legend>
                    <div class="category-options">
                        @foreach (var category in Model.Categories)
                        {
                            <label>
                                <input type="checkbox"
                                       name="categoryIds"
                                       value="@category.Id"
                                       checked="@Model.SelectedCategoryIds.Contains(category.Id)" />
                                <span>@category.Name</span>
                            </label>
                        }
                    </div>
                </fieldset>

                <div class="advanced-actions">
                    @if (Model.HasAdvancedFilters)
                    {
                        <a href="@BuildUrl(clearAdvanced: true)">Xóa bộ lọc nâng cao</a>
                    }
                    <button type="submit">Áp dụng bộ lọc</button>
                </div>
            </section>
        </form>

        <nav class="search-tabs" aria-label="Loại kết quả">
            <a class="@(Model.Tab == "all" ? "active" : null)" href="@BuildUrl(tab: "all")">☷ Tất cả</a>
            <a class="@(Model.Tab == "novels" ? "active" : null)" href="@BuildUrl(tab: "novels")">▥ Truyện</a>
            <a class="@(Model.Tab == "members" ? "active" : null)" href="@BuildUrl(tab: "members")">♙ Thành viên</a>
        </nav>

        @if (Model.Query.Length is > 0 and < 2)
        {
            <div class="search-empty">Vui lòng nhập tối thiểu 2 ký tự.</div>
        }
        else if (Model.TotalCount == 0)
        {
            <div class="search-empty">Không tìm thấy kết quả phù hợp.</div>
        }

        @if (Model.NovelResults.Any())
        {
            <section class="result-section">
                <h2>▥ Tác phẩm</h2>
                <div class="result-list">
                    @foreach (var novel in Model.NovelResults)
                    {
                        <article class="novel-result-card">
                            <a class="result-cover" asp-controller="Novel" asp-action="Detail" asp-route-id="@novel.Id">
                                <img src="@novel.CoverImage" alt="@novel.Title" />
                                <span>@novel.Status</span>
                            </a>
                            <div class="result-body">
                                <div class="result-title-row">
                                    <h3>
                                        <a asp-controller="Novel" asp-action="Detail" asp-route-id="@novel.Id">@novel.Title</a>
                                    </h3>
                                    <span class="rating-pill">★ 5.0</span>
                                </div>
                                <p class="result-meta">
                                    ♙ <a class="user-name-link @(novel.IsAuthorInactive ? "inactive-user-name-inline" : null)"
                                          asp-controller="Profile"
                                          asp-action="Detail"
                                          asp-route-id="@novel.AuthorId">@novel.Author</a>
                                    · <span>@novel.Category</span>
                                </p>
                                <p class="result-summary">@novel.Synopsis</p>
                                <div class="result-stats">
                                    <span>☰ @novel.ChapterCount</span>
                                    <span>⊙ @novel.ViewCount.ToString("N0")</span>
                                    <span>◷ @novel.UpdatedText</span>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </section>
        }

        @if (Model.MemberResults.Any())
        {
            <section class="result-section">
                <h2>♙ Thành viên</h2>
                <div class="member-grid">
                    @foreach (var member in Model.MemberResults)
                    {
                        <article class="member-card">
                            <a class="member-avatar" asp-controller="Profile" asp-action="Detail" asp-route-id="@member.Id">@member.Initials</a>
                            <div>
                                <h3>
                                    <a class="@(member.IsInactive ? "inactive-user-name-inline" : null)"
                                       asp-controller="Profile"
                                       asp-action="Detail"
                                       asp-route-id="@member.Id">@member.DisplayName</a>
                                </h3>
                                <p>@@@member.Username · @member.Role</p>
                                <span>@member.NovelCount truyện đã đăng</span>
                                <small>@member.Bio</small>
                            </div>
                        </article>
                    }
                </div>
            </section>
        }
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const toggle = document.getElementById('advancedSearchToggle');
            const panel = document.getElementById('advancedSearchPanel');

            if (!toggle || !panel) return;

            toggle.addEventListener('click', () => {
                const isOpening = panel.hidden;
                panel.hidden = !isOpening;
                toggle.setAttribute('aria-expanded', isOpening.toString());

                if (isOpening) {
                    panel.querySelector('input, select')?.focus();
                }
            });
        })();
    </script>
}
