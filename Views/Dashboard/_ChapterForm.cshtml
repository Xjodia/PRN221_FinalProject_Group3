@model PRN221_FinalProject_Group3.Models.ViewModels.ChapterFormViewModel

<div asp-validation-summary="ModelOnly" class="validation-summary"></div>
<input asp-for="NovelId" type="hidden" />

<div class="form-grid">
    <label asp-for="ChapterNumber">Số chương</label>
    <div>
        <input asp-for="ChapterNumber" type="number" step="0.01" min="0" />
        <span asp-validation-for="ChapterNumber"></span>
    </div>

    <label asp-for="Title">Tên chương *</label>
    <div>
        <input asp-for="Title" />
        <span asp-validation-for="Title"></span>
    </div>

    <label asp-for="Content">Nội dung *</label>
    <div>
        <textarea asp-for="Content" class="js-rte tall-editor" rows="18"></textarea>
        <span asp-validation-for="Content"></span>
    </div>
</div>
